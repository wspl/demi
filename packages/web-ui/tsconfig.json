{
  "extends": ["../../tsconfig.json", "@vue/tsconfig/tsconfig.dom.json"],
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["bun"],
    "paths": {
      "@demi/web-ui/*": ["./src/*"],
      "@demi/*": ["../*/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
