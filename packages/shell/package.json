  "scripts": {
    "build": "tsdown"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wspl/demi.git",
    "directory": "packages/shell"
  },
  "homepage": "https://github.com/wspl/demi/tree/main/packages/shell#readme",
