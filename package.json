{
  "name": "demi",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/coding-agent",
    "packages/agent",
    "packages/core",
    "packages/utils",
    "packages/host-local",
    "packages/provider",
    "packages/provider-codex",
    "packages/provider-claude-code",
    "packages/provider-openai-api",
    "packages/provider-anthropic-api",
    "packages/provider-grok-build",
    "packages/shell",
    "packages/repl",
    "packages/web-ui",
    "packages/agent-eval",
    "packages/web",
    "packages/just-bash/packages/just-bash"
  ],
  "scripts": {
    "check:registry": "bun run scripts/check-public-registry.ts",
    "typecheck": "tsgo --noEmit",
    "typecheck:web": "bun --filter @demicodes/web-ui typecheck && bun --filter @demicodes/web typecheck",
    "build": "bun --filter '@demicodes/*' build",
    "llms": "bun run scripts/build-llms.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "bun run scripts/release.ts",
    "web:dev": "bun --filter @demicodes/web dev",
    "web:server": "bun run packages/web/src/server/index.ts",
    "test": "bun test --conditions development packages/utils/src packages/core/src packages/provider/src packages/agent/src packages/shell/src packages/host-local/src packages/coding-agent/src packages/provider-codex/src packages/provider-claude-code/src packages/provider-openai-api/src packages/provider-anthropic-api/src packages/provider-grok-build/src packages/repl/src packages/web-ui/src packages/web/src packages/agent-eval/src",
    "test:just-bash-core": "bun test packages/just-bash/packages/just-bash/src/syntax/parser-protection.test.ts packages/just-bash/packages/just-bash/src/syntax/parser-edge-cases.test.ts packages/just-bash/packages/just-bash/src/syntax/parse-errors.test.ts",
    "repl": "bun run packages/repl/src/index.ts",
    "agent-eval": "bun run packages/agent-eval/src/cli.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260618.1",
    "oxc-parser": "^0.137.0",
    "tsdown": "^0.22.3",
    "unrun": "^0.3.1"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wspl/demi.git"
  },
  "homepage": "https://github.com/wspl/demi#readme",
  "bugs": "https://github.com/wspl/demi/issues"
}
